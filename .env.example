# ==============================================================================
# AgentForge — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Anthropic (required — used for both agent tasks AND vector embeddings)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------------------------
# Model selection
# ------------------------------------------------------------------------------
MODEL_NAME=claude-opus-4-5              # Primary model for all agent reasoning
EMBEDDING_MODEL=claude-haiku-4-5-20251001  # Fast/cheap model for RAG embeddings

# ------------------------------------------------------------------------------
# Web Search — Tavily (optional: mock search used automatically if blank)
# ------------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-key-here

# ------------------------------------------------------------------------------
# Model parameters
# ------------------------------------------------------------------------------
MAX_TOKENS=4096
TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# Orchestration & feedback loop
# ------------------------------------------------------------------------------
MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
ENABLE_CRITIC=true
ENABLE_FEEDBACK_LOOP=true
FEEDBACK_SCORE_THRESHOLD=6.0    # Critic score below this triggers agent retries
MAX_FEEDBACK_ITERATIONS=2       # Max retry rounds per run

# ------------------------------------------------------------------------------
# Short-term memory (KV)
# ------------------------------------------------------------------------------
MEMORY_BACKEND=in_memory        # Options: in_memory | diskcache
MEMORY_DIR=.cache/memory

# ------------------------------------------------------------------------------
# Long-term vector memory (FAISS + Claude embeddings)
# Embeddings are produced by EMBEDDING_MODEL via structured JSON prompt.
# No sentence-transformers or downloaded model weights required.
# ------------------------------------------------------------------------------
ENABLE_VECTOR_MEMORY=true
VECTOR_MEMORY_DIR=.cache/vector_memory
RAG_TOP_K=5                     # Chunks retrieved per query
RAG_CHUNK_SIZE=512              # Characters per chunk
RAG_CHUNK_OVERLAP=64            # Overlap between consecutive chunks

# ------------------------------------------------------------------------------
# Output
# ------------------------------------------------------------------------------
ARTIFACTS_DIR=.artifacts

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console              # console | json
